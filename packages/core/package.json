{
  "name": "@muscat/core",
  "version": "0.0.0",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "pnpm test:unit",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:coverage": "rimraf coverage && vitest run --config vitest.config.ts --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "xstate": "^5.21.0"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@vitest/coverage-istanbul": "^3.2.4",
    "rimraf": "^6.0.1",
    "vite": "^8.0.0"
  }
}
