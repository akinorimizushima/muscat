{
  "name": "muscat",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck",
    "dev": "pnpm --filter @muscat/demo dev",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint --deny-warnings .",
    "lint:fix": "oxlint --fix --deny-warnings .",
    "test": "pnpm -r test",
    "test:browser": "pnpm -r --if-present test:browser",
    "test:coverage": "pnpm --filter @muscat/core test:coverage",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": "24.6.0"
  },
  "packageManager": "pnpm@11.14.0"
}
