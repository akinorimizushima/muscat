{
  "name": "muscat",
  "private": true,
  "packageManager": "pnpm@10.15.0",
  "engines": {
    "node": "24.6.0"
  },
  "pnpm": {
    "executionEnv": {
      "nodeVersion": "24.6.0"
    }
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @muscat/demo dev",
    "test": "pnpm -r test",
    "test:browser": "pnpm --filter @muscat/core test:browser",
    "test:coverage": "pnpm --filter @muscat/core test:coverage",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
